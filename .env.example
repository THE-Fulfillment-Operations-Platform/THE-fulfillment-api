# ---- App ----
APP_ENV=development
APP_NAME=THE Fulfillment API
PORT=8080

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=the_fulfillment
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh

# ---- Auth (JWT) ----
# CHANGE THIS in production. Used to sign/verify JWTs.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=72

# ---- CORS ----
# Comma-separated origins, or * to echo any origin (handy for local FE dev).
CORS_ALLOWED_ORIGINS=*

# ---- Seed ----
# Seed demo data (roles, users per role, materials, SKUs, sellers, demo orders) on startup.
SEED_ON_START=true
# Password assigned to every seeded demo user.
SEED_DEMO_PASSWORD=Password123!
