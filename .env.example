# ---- App ----
APP_ENV=development
APP_NAME=THE Fulfillment API
PORT=8080

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=the_fulfillment
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh

# ---- Auth (JWT) ----
# Secret used to sign/verify JWTs. In production the server REFUSES to boot if
# this is left at the default or is shorter than 32 chars (a weak/known key lets
# anyone forge a token for any user). Generate one, e.g.: openssl rand -base64 48
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=72

# ---- CORS ----
# Comma-separated origins, or * to echo any origin (handy for local FE dev).
CORS_ALLOWED_ORIGINS=*

# ---- Seed ----
# Seed master data (roles, materials, SKUs, seller) on startup.
SEED_ON_START=true
# Seed the demo login accounts (owner@the.local … with SEED_DEMO_PASSWORD). These
# are REAL working credentials — set false in production. In production the server
# refuses to boot if this is on while SEED_DEMO_PASSWORD is still the default.
SEED_DEMO_USERS=true
# Seed the 4 demo orders too. Keep false so a data reset re-import starts from an
# empty order set (master data still seeds via SEED_ON_START).
SEED_DEMO_ORDERS=false
# Password assigned to every seeded demo user.
SEED_DEMO_PASSWORD=Password123!

# ---- Danger zone ----
# Kill-switch for POST /api/admin/reset (OWNER only) — wipes all order/production
# data so the catalog can be re-imported from scratch. Works in any environment,
# including production, when true; the route is still guarded by the OWNER role
# and a typed confirmation. Set false to disable the feature entirely.
ALLOW_DATA_RESET=false
